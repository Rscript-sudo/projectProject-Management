{
  "name": "project-management-system",
  "version": "1.0.0",
  "description": "项目文档管理系统 - AI 文档生成",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -n renderer,electron \"vite\" \"wait-on tcp:5173 && electron . --dev\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "preview": "electron-builder --dir && open ./dist/mac/项目文档管理系统.app"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.0",
    "antd": "^5.24.0",
    "better-sqlite3": "^12.11.1",
    "docx": "^8.5.0",
    "docxtemplater": "^3.68.7",
    "flexsearch": "^0.8.212",
    "mammoth": "^1.12.0",
    "pizzip": "^3.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.15.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.2",
    "electron": "^42.2.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.60.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "wait-on": "^8.0.3",
    "ws": "^8.20.1"
  },
  "build": {
    "appId": "com.supervision.project-management",
    "productName": "项目文档管理系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "resources/**/*",
      "templates/**/*"
    ],
    "extraResources": [
      {
        "from": "templates",
        "to": "templates",
        "filter": [
          "**/*",
          "!format-spec/**"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.png",
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "language": "2052",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "shortcutName": "项目文档管理系统",
      "createDesktopShortcut": true
    }
  }
}
