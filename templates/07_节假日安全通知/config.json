{
  "name": "节假日监理安全通知书",
  "doc_type": "holiday",
  "engine": "docx",
  "template": "./节假日监理安全通知书模版.docx",
  "output": {
    "dir": "03_实施阶段/06_往来函件/02_监理安全通知书/原始稿/",
    "naming": "{YYYYMMDD}_JL-TZ_{PROJECT_CODE}_{SUBJECT_SNIPPET}.docx"
  },
  "counter_key": "节假日通知",
  "placeholders": {
    "{{项目名称}}": {
      "source": "env",
      "key": "PROJECT_NAME"
    },
    "{{文件编号}}": {
      "source": "computed",
      "key": "COUNTER",
      "default": ""
    },
    "{{致单位}}": {
      "source": "env",
      "key": "CONTRACTOR"
    },
    "{{事由}}": {
      "source": "param",
      "key": "subject",
      "default": "关于{节日名称}期间施工现场安全管理要求"
    },
    "{{正文内容}}": {
      "source": "param",
      "key": "body_content",
      "default": ""
    },
    "{{施工单位}}": {
      "source": "env",
      "key": "CONTRACTOR"
    },
    "{{总监姓名}}": {
      "source": "env",
      "key": "CHIEF_ENGINEER"
    },
    "{{节日名称}}": {
      "source": "param",
      "key": "holiday_name",
      "default": "春节"
    },
    "{{放假日期}}": {
      "source": "param",
      "key": "holiday_period",
      "default": ""
    },
    "{{日期}}": {
      "source": "computed",
      "key": "TODAY"
    }
  },
  "triggers": [
    "节假日安全通知",
    "节假日通知",
    "节日安全提醒",
    "holiday"
  ],
  "requires": [
    "GLOBAL_RULES"
  ],
  "light_mode": true
}