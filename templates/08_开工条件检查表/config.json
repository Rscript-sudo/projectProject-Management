{
  "name": "开工条件检查表",
  "doc_type": "startup_check",
  "engine": "docx",
  "template": "./开工条件检查表_模版.docx",
  "output": {
    "dir": "02_准备阶段/04_开工报审/01_开工条件检查表/",
    "naming": "{YYYYMMDD}_KG-JC_{PROJECT_CODE}_开工条件检查表.docx"
  },
  "counter_key": "开工条件检查",
  "placeholders": {
    "{{项目名称}}": {
      "source": "env",
      "key": "PROJECT_NAME"
    },
    "{{建设单位}}": {
      "source": "env",
      "key": "OWNER"
    },
    "{{施工单位}}": {
      "source": "env",
      "key": "CONTRACTOR"
    },
    "{{设备厂家}}": {
      "source": "param",
      "key": "equipment_vendor",
      "default": ""
    },
    "{{监理单位}}": {
      "source": "env",
      "key": "SUPERVISOR_UNIT"
    },
    "{{检查日期}}": {
      "source": "computed",
      "key": "TODAY"
    }
  },
  "triggers": [
    "开工条件检查",
    "开工检查",
    "startup_check"
  ],
  "light_mode": true
}